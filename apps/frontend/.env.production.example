# Vercel Production Environment Variables
# Add these in Vercel Dashboard → Project Settings → Environment Variables

# ============================================
# API CONFIGURATION (CRITICAL)
# ============================================
# Point to your Railway backend deployment
NEXT_PUBLIC_API_URL=https://your-railway-app.up.railway.app/api/v1

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production

# ============================================
# VERCEL ANALYTICS (Optional)
# ============================================
# Automatically available in Vercel, no setup needed
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID is auto-injected

# ============================================
# VERCEL SPEED INSIGHTS (Optional)
# ============================================
# Enable in Vercel Dashboard → Analytics tab
# NEXT_PUBLIC_VERCEL_SPEED_INSIGHTS_ID is auto-injected

# ============================================
# IMAGE OPTIMIZATION
# ============================================
# Vercel handles image optimization automatically
# Configure domains in next.config.ts

# ============================================
# NOTES
# ============================================
# 1. Update NEXT_PUBLIC_API_URL with your actual Railway backend URL
# 2. Never commit secrets to git
# 3. All NEXT_PUBLIC_* variables are exposed to the browser
# 4. Vercel automatically injects system variables
# 5. To test locally with production build:
#    cp .env.production .env.production.local
#    pnpm build && pnpm start

# ============================================
# VERCEL SYSTEM VARIABLES (Auto-injected)
# ============================================
# These are automatically available in Vercel deployments:
# - VERCEL: "1"
# - VERCEL_ENV: "production" | "preview" | "development"
# - VERCEL_URL: deployment URL
# - VERCEL_BRANCH_URL: branch-specific URL
# - VERCEL_GIT_COMMIT_SHA: git commit SHA
# - VERCEL_GIT_COMMIT_MESSAGE: commit message
# - VERCEL_GIT_COMMIT_AUTHOR_LOGIN: commit author
# - VERCEL_GIT_COMMIT_AUTHOR_NAME: commit author name
# - VERCEL_GIT_REPO_SLUG: repository name
# - VERCEL_GIT_REPO_OWNER: repository owner
# - VERCEL_GIT_REPO_ID: repository ID
# - VERCEL_GIT_PROVIDER: git provider (github/gitlab/bitbucket)
