# ====================================
# Medium Clone - Backend Environment Variables
# ====================================

# Application
NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=blog_platform
DB_SYNC=true  # Auto-sync schema (DISABLE IN PRODUCTION!)
DB_LOGGING=true  # SQL query logging

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# File Storage
# Options: 'local' or 's3'
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# AWS S3 (only if STORAGE_PROVIDER=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_S3_BUCKET=your-bucket-name

# Rate Limiting
THROTTLE_TTL=60  # Time window in seconds
THROTTLE_LIMIT=100  # Max requests per window

# Email (for future implementation)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@blog-platform.com

# ====================================
# Production Notes
# ====================================
# 1. Change all secrets to strong random values
# 2. Set DB_SYNC=false (never auto-sync in production!)
# 3. Set DB_LOGGING=false (reduces noise)
# 4. Use S3 for file storage (STORAGE_PROVIDER=s3)
# 5. Configure proper CORS_ORIGIN
# 6. Set NODE_ENV=production

# Railway Auto-Injected Variables:
# - DATABASE_URL (use this instead of DB_* if provided)
# - PORT (Railway sets this automatically)

# To use DATABASE_URL instead of individual DB_* vars:
# Uncomment and set DATABASE_URL, then remove/comment DB_HOST, DB_PORT, etc.
# DATABASE_URL=postgresql://user:password@host:port/database
